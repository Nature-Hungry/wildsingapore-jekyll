{% assign random_posts = site.entries | sample: 4 %}
[
{% for post in random_posts %}
{
  "title": {{ post.title | jsonify }},
  "url": {{ post.url | jsonify }}, 
  "coverimg": {{ post.smallcoverimg | default: post.coverimg | jsonify }}, 
  
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]